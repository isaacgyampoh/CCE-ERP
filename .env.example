# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # Service role key — server only!

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx       # Server only — never expose!

# ─── SendGrid (Email) ─────────────────────────────────────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys
# Admission letters + school fee invoices sent via email
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=admissions@cambridgecoe.edu.gh
SENDGRID_FROM_NAME=Cambridge Center of Excellence

# ─── WhatsApp Business API (Optional) ────────────────────────────────────────
# If you have a Meta Business WhatsApp API account (Green tick number)
# If NOT configured, the system will fall back to wa.me links (manual open)
WABA_TOKEN=EAAxxxx...         # WhatsApp Business Access Token
WABA_PHONE_ID=1234567890      # WhatsApp Business Phone Number ID

# ─── Google Sheets Webhook (Optional) ────────────────────────────────────────
# Apps Script web app URL — receives POST on every registration payment
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_ID/exec

# ─── App URL ──────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (used for internal API calls in webhooks)
APP_URL=https://cce-erp.vercel.app
